// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURATION
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum OrderType {
  order
  custom_order
}

enum CustomPaymentStage {
  down_payment
  final_payment
  standard_full
}

enum PaymentType {
  e_wallet
  bank_transfer
}

enum OrderStatus {
  pending
  processing
  shipped
  completed
  cancelled
}

enum PaymentStatus {
  pending
  waiting_verification
  completed
  failed
}

enum ConsultationStatus {
  pending
  completed
  cancelled
}

enum ProgressStatus {
  pending
  proses
  selesai
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS, ROLES & ACCESS CONTROL
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  level       Int
  description String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  accesses    Access[]
  users       User[]

  @@map("roles")
}

model Access {
  id         Int      @id @default(autoincrement())
  role_id    Int
  page_id    Int
  name       String
  create     Boolean
  read       Boolean
  update     Boolean
  delete     Boolean
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  page       Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@map("accesses")
}

model Page {
  id         Int      @id @default(autoincrement())
  nomor      Int
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  accesses   Access[]

  @@map("pages")
}

model User {
  id                 Int       @id @default(autoincrement())
  role_id            Int
  name               String
  email              String    @unique
  password           String
  phone              String?
  address            String
  image              String?
  email_verified_at  DateTime?
  verification_token String?   @unique
  last_login         DateTime?
  remember_token     String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  carts              Cart[]
  cart_items         CartItem[]
  orders             Order[]
  custom_orders      CustomOrder[]
  consultations      Consultation[]
  projects           Project[]
  project_members    ProjectMember[]
  production_logs    ProductionLog[]
  salary_logs        SalaryLog[]
  work_logs          WorkLog[]
  staffs             Staff[]
  salaryPayments     SalaryPayment[]

  role               Role      @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@map("users")
}

model Session {
  id            String  @id
  user_id       Int?
  ip_address    String? @db.VarChar(45)
  user_agent    String?
  payload       String
  last_activity Int

  @@map("sessions")
}

model PasswordResetToken {
  email      String    @id
  token      String
  created_at DateTime?

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOM ORDER CATALOG (untuk Custom Order)
// ─────────────────────────────────────────────────────────────────────────────

model CustomVariant {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    Boolean  @default(true) 
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  options   VariantOption[]

  @@map("custom_variants")
}

model VariantOption {
  id                Int      @id @default(autoincrement())
  custom_variant_id Int
  name              String?
  status            Boolean  @default(true) 
  description       String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  custom_variant    CustomVariant @relation(fields: [custom_variant_id], references: [id], onDelete: Cascade)
  customOrderItemOptions CustomOrderItemOption[]

  @@map("variant_options")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT CATALOG (untuk Produk Reguler)
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  status    Boolean   @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products  Product[]

  @@map("categories")
}

model Size {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  variants  ProductVariant[]

  @@map("sizes")
}

model Color {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  hex_code  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  variants  ProductVariant[]

  @@map("colors")
}

model Attribute {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("attributes")
}

model Material {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  products    Product[]

  @@map("materials")
}

model Product {
  id          Int      @id @default(autoincrement())
  category_id Int
  name        String?
  material_id Int?
  description String?
  price       Int?
  image       String?
  status      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category    Category         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  material    Material?        @relation(fields: [material_id], references: [id], onDelete: SetNull)
  variants    ProductVariant[]
  carts       Cart[]
  cart_items  CartItem[]
  order_items OrderItem[]

  @@map("products")
}

model ProductVariant {
  id               Int    @id @default(autoincrement())
  product_id       Int
  size_id          Int?
  color_id         Int?
  image            String?
  description      String?
  stock            Int
  price_adjustment Int    @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size    Size?   @relation(fields: [size_id], references: [id], onDelete: SetNull)
  color   Color?  @relation(fields: [color_id], references: [id], onDelete: SetNull)

  carts        Cart[]
  cart_items   CartItem[]
  order_items  OrderItem[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTIONAL (CART & ORDERS) - untuk Produk Reguler
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  product_id          Int
  product_variant_id  Int
  quantity            Int      @default(1)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user               User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product            Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_variant    ProductVariant @relation(fields: [product_variant_id], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id           Int            @id @default(autoincrement())
  user_id      Int
  product_id   Int
  variant_id   Int
  quantity     Int
  price_at_add Int?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  user         User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Order {
  id               Int             @id @default(autoincrement())
  user_id          Int
  order_number     String          @unique
  status           OrderStatus     @default(pending)
  grand_total      Int
  shipping_address String
  shipping_cost    Int
  payment_method   String
  tracking_code    String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order_items      OrderItem[]
  trackings        Tracking[]
  production_logs  ProductionLog[]
  work_logs        WorkLog[]
  payment          Payment?
  projects         Project[]

  @@map("orders")
}

model OrderItem {
  id         Int            @id @default(autoincrement())
  order_id   Int
  product_id Int
  variant_id Int?
  quantity   Int
  price      Int?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  order      Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOM ORDERS & PROJECTS
// ─────────────────────────────────────────────────────────────────────────────

model CustomOrder {
  id               Int              @id @default(autoincrement())
  user_id          Int
  name             String?
  phone            String?
  email            String?
  deadline         DateTime?
  catatan_tambahan String?
  images           String?          // JSON string array of image paths
  dp_amount        Int?
  remaining_amount Int?
  total_amount     Int?
  accept_status    Boolean          @default(false)
  payment_status   Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments Payment[]
  items    CustomOrderItem[]
  projects Project[]
  work_logs WorkLog[]

  @@map("custom_orders")
}

model CustomOrderItem {
  id                Int      @id @default(autoincrement())
  custom_order_id   Int
  quantity          Int      @default(0)
  remaining_quantity Int     
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  custom_order      CustomOrder @relation(fields: [custom_order_id], references: [id], onDelete: Cascade)
  selected_options  CustomOrderItemOption[]
  progressReports   ProgressReport[]  // ✅ TAMBAH: relasi ke ProgressReport

  @@map("custom_order_items")
}

model CustomOrderItemOption {
  id                   Int      @id @default(autoincrement())
  custom_order_item_id Int
  variant_option_id    Int
  created_at           DateTime @default(now())

  custom_order_item CustomOrderItem @relation(fields: [custom_order_item_id], references: [id], onDelete: Cascade)
  variant_option    VariantOption   @relation(fields: [variant_option_id], references: [id], onDelete: Cascade)

  @@unique([custom_order_item_id, variant_option_id])
  @@map("custom_order_item_options")
}

model Project {
  id              Int             @id @default(autoincrement())
  user_id         Int
  custom_order_id Int?            @unique
  order_id        Int?            @unique
  status          Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  custom_order    CustomOrder?    @relation(fields: [custom_order_id], references: [id], onDelete: Cascade)
  order           Order?          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  progressReports ProgressReport[]
  salaryProjects  SalaryProjects[]

  @@map("projects")
}

model ProjectMember {
  project_id    Int
  user_id       Int
  assigned_name String?
  assigned_at   DateTime @default(now())

  project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([project_id, user_id])
  @@map("project_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS & LOGISTICS
// ─────────────────────────────────────────────────────────────────────────────

model PaymentMethod {
  id                       Int         @id @default(autoincrement())
  bank_code                String      @unique
  bank_name                String
  bank_account             String
  owner_name               String
  type                     PaymentType
  status_method            Boolean     @default(true)
  expired_duration_minutes Int         @default(60)
  created_at               DateTime    @default(now())
  updated_at               DateTime    @updatedAt

  payments                 Payment[]

  @@map("payment_methods")
}

model Logistic {
  id          Int      @id @default(autoincrement())
  name        String?  @unique
  alias       String?  @unique
  description String?
  status      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("logistics")
}

model Payment {
  id                Int           @id @default(autoincrement())
  custom_order_id   Int?
  order_id          Int?          @unique
  payment_method_id Int?
  amount            Int?
  paid_at           DateTime?
  payment_proof     String?
  payment_status    PaymentStatus @default(pending)
  order_type        OrderType     @default(order)
  payment_stage     CustomPaymentStage @default(standard_full)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  custom_order   CustomOrder?  @relation(fields: [custom_order_id], references: [id], onDelete: Cascade)
  order          Order?        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])
  transactions   Transaction[]

  @@map("payments")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  payment_id Int
  amount     Int?
  type       String?
  reference  String?
  note       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  payment    Payment  @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACKING & CONSULTATION
// ─────────────────────────────────────────────────────────────────────────────

model Tracking {
  id                   Int               @id @default(autoincrement())
  order_id             Int
  current_stage        String
  progress_percentage  Int
  estimated_completion DateTime
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  order                Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)
  tracking_histories   TrackingHistory[]

  @@map("trackings")
}

model TrackingHistory {
  id          Int      @id @default(autoincrement())
  tracking_id Int
  status      String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tracking    Tracking @relation(fields: [tracking_id], references: [id], onDelete: Cascade)

  @@map("tracking_histories")
}

model Consultation {
  id                    Int                    @id @default(autoincrement())
  user_id               Int
  message               String?
  quantity_estimate     String?
  status                ConsultationStatus     @default(pending)
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  user                  User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  consultation_files    ConsultationFile[]
  consultation_materials ConsultationMaterial[]

  @@map("consultations")
}

model ConsultationFile {
  id              Int          @id @default(autoincrement())
  consultation_id Int
  file_name       String
  file_path       String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  consultation    Consultation @relation(fields: [consultation_id], references: [id], onDelete: Cascade)

  @@map("consultation_files")
}

model ConsultationMaterial {
  id              Int          @id @default(autoincrement())
  consultation_id Int
  material_name   String
  material_type   String
  color_require   String?
  sample_required Boolean      @default(false)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  consultation    Consultation @relation(fields: [consultation_id], references: [id], onDelete: Cascade)

  @@map("consultation_materials")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTION, SALARY & PORTFOLIO
// ─────────────────────────────────────────────────────────────────────────────

model Staff {
  id          Int       @id @default(autoincrement())
  user_id     Int       @unique
  tgl_masuk   DateTime? @db.Date
  salary      Int?      @default(0)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  staffStages     StaffStage[]
  salaryProjects  SalaryProjects[]
  progressReports ProgressReport[]
  salaryPayments  SalaryPayment[]

  @@map("staffs")
}

model StaffStage {
  staff_id Int
  stage_id Int

  staff Staff @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  stage Stage @relation(fields: [stage_id], references: [id], onDelete: Cascade)

  @@id([staff_id, stage_id])
  @@map("staff_stages")
}

model SalaryProjects {
  id                Int       @id @default(autoincrement())
  staff_id          Int
  project_id        Int
  adjustment_salary Int?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  staff   Staff   @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([staff_id, project_id])
  @@map("salary_projects")
}

model Stage {
  id          Int       @id @default(autoincrement())
  stage_name  String    @unique
  order_index Int       @default(0)
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  work_logs        WorkLog[]
  progressReports  ProgressReport[]
  staffStages      StaffStage[]

  @@map("stages")
}

model ProductionLog {
  id          Int      @id @default(autoincrement())
  order_id    Int
  user_id     Int
  action_type String
  old_value   String?
  new_value   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("production_logs")
}

model SalaryLog {
  id           Int      @id @default(autoincrement())
  user_id      Int
  amount       Int
  bonus        Int      @default(0)
  deduction    Int      @default(0)
  total_salary Int
  period_start DateTime @db.Date
  period_end   DateTime @db.Date
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("salary_logs")
}

model Portofolio {
  id          Int      @id @default(autoincrement())
  name        String?
  image       String?
  description String?
  order       Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("portofolios")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK LOG
// ─────────────────────────────────────────────────────────────────────────────

model WorkLog {
  id              Int      @id @default(autoincrement())
  user_id         Int
  stage_id        Int
  order_type      String
  custom_order_id Int?
  sport_order_id  Int?
  quantity        Int
  earned_amount   Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  stage           Stage         @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  custom_order    CustomOrder?  @relation(fields: [custom_order_id], references: [id], onDelete: Cascade)
  sport_order     Order?        @relation(fields: [sport_order_id], references: [id], onDelete: Cascade)

  @@map("work_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROGRESS REPORT
// ─────────────────────────────────────────────────────────────────────────────

model ProgressReport {
  id                Int             @id @default(autoincrement())
  staff_id          Int
  project_id        Int
  custom_order_item_id Int?         // ✅ TAMBAH: relasi ke CustomOrderItem
  stage_id          Int
  status            ProgressStatus  @default(pending)
  quantity          Int?
  catatan           String?
  image             String?
  approval_status   Boolean?        @default(false)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  staff             Staff         @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  project           Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  custom_order_item CustomOrderItem? @relation(fields: [custom_order_item_id], references: [id], onDelete: Cascade)  // ✅ TAMBAH
  stage             Stage         @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  salaryPaymentDetail SalaryPaymentDetail?

  @@map("progress_reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// SALARY PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model SalaryPayment {
  id            Int       @id @default(autoincrement())
  staff_id      Int
  paid_by       Int
  total_amount  Int?
  payment_date  DateTime  @default(now())
  proof         String?
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  staff         Staff     @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  finance       User      @relation(fields: [paid_by], references: [id], onDelete: Cascade)
  details       SalaryPaymentDetail[]

  @@map("salary_payments")
}

model SalaryPaymentDetail {
  id                 Int            @id @default(autoincrement())
  salary_payment_id  Int
  progress_report_id Int            @unique
  amount             Int?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  salaryPayment      SalaryPayment  @relation(fields: [salary_payment_id], references: [id], onDelete: Cascade)
  progressReport     ProgressReport @relation(fields: [progress_report_id], references: [id], onDelete: Cascade)

  @@map("salary_payment_details")
}